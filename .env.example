# ============================================================
# Media Stack - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Paden (pas aan voor lokale ontwikkeling of Synology) ---
# Synology:
MEDIA_PATH=/volume1/Media
DOCKER_PATH=/volume1/docker_data
DB_PATH=/volume2/Databases_SSD

# Lokaal voorbeeld:
# MEDIA_PATH=/home/youruser/media
# DOCKER_PATH=/home/youruser/docker
# DB_PATH=/home/youruser/databases

# --- Tijdzone ---
TZ=Europe/Amsterdam

# --- PUID / PGID (draai 'id' op je server om de juiste waarden te vinden) ---
PUID=1000
PGID=1000

# --- Poorten (pas aan als er conflicten zijn) ---
PORT_SABNZBD=8080
PORT_PROWLARR=9696
PORT_SONARR=8989
PORT_RADARR=7878
PORT_LIDARR=8686
PORT_BAZARR=6767
PORT_JELLYFIN=8096
PORT_JELLYSEERR=5055
PORT_SPOTWEB=8085
PORT_SPOTTARR=8383



USENET__HOSTNAME="my.news.server.com"
USENET__USERNAME="username"
USENET__PASSWORD="somep@ssw0rd"
USENET__PORT="563"
USENET__USETLS="true"
USENET__MAXCONNECTIONS="10" # Adjust based on your usenet provider and other download clients


# --- Watchtower ---
# Hoe vaak Watchtower controleert op nieuwe images (in seconden)
# 3600 = elk uur, 21600 = elke 6 uur
WATCHTOWER_POLL_INTERVAL=21600

# Notificaties via Apprise URL (bijv. Discord, Slack, Telegram, e-mail)
# Voorbeelden:
#   Discord:  discord://webhook-id/webhook-token
#   Telegram: tgram://bottoken/chatid
#   Slack:    slack://tokenA/tokenB/tokenC/channel
# Laat leeg om notificaties uit te schakelen
WATCHTOWER_NOTIFICATION_URL=

# --- GitHub Container Registry (voor Watchtower authenticatie indien nodig) ---
# Vul in als je private images gebruikt
# GHCR_USER=jouw-github-username
# GHCR_TOKEN=ghp_xxxxxxxxxxxx
